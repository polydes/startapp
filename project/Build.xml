<xml>

<pragma once="true" />

<set name="id" value="com.byrobin.startapp" />

<error value="The ${id} extension only provides native code for iOS" unless="ios" />

<files id="${id}-dependencies">
  <depend files="hxcpp-depends" />
  <depend name="${this_dir}/Build.xml" dateOnly="true" />
  <depend name="${this_dir}/include/StartAppEx.h" />
</files>

<cocoapod name="StartAppSdk" version="3.10.2" />

<files id="${id}-ios" dir="${this_dir}">
  <depend files="${id}-dependencies" />
  <cache value="1" project="${id}" asLibrary="true" />
  <compilerflag value="-I${this_dir}/include" />
  <compilerflag value="-F${cocoapod:StartAppSdk.frameworks.StartApp.dir}"/>
  <file name="common/ExternalInterface.cpp" />
  <file name="ios/StartAppEx.mm"/>
</files>

<target id="haxe">
  <files id="com.byrobin.startapp-ios" if="ios" />
</target>

<unset name="id" />

</xml>
